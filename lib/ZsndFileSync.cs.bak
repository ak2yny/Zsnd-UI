        internal readonly FileEvents FileEvents = new();

        internal ZsndFile()
        {
            _updating = true;
            PlatformInfo = new("PC");
            Name = ExtractedDirName = "NEWFILE";
            SetJsonDir(Settings.Shared.UI.ExtractedAssetsPath);
            ZsndFilePath = "";
            Json = new();
            FilteredSounds = new(Sounds);
            Samples = new(Json.Samples);
            _updating = false;
        }

        internal ZsndFile(string FilePath, string Extension, string DisplayName) => LoadFile(FilePath, Extension, DisplayName);

        [MemberNotNull(nameof(JsonDir), nameof(JsonFilePath))]
        public void SetJsonFilePath(string value) { JsonDir = Path.GetDirectoryName(value)!; JsonFilePath = value; }

        [MemberNotNull(nameof(JsonDir), nameof(JsonFilePath))]
        public void SetJsonDir(string value) { JsonFilePath = Path.Combine(value, $"{Name}.json"); JsonDir = value; }

        [MemberNotNull(nameof(PlatformInfo), nameof(FilteredSounds), nameof(Samples), nameof(ExtractedDirName),
            nameof(Name), nameof(Json), nameof(JsonDir), nameof(JsonFilePath), nameof(ZsndFilePath))]
        internal void LoadFile(string FilePath, string Extension, string DisplayName)
        {
            _updating = true;
            Name = ExtractedDirName = DisplayName; // Path.GetFileName(FilePath)[..^Extension.Length];
            if (Extension.Equals(".json", StringComparison.OrdinalIgnoreCase))
            {
                ZsndFilePath = $"{FilePath[..^Extension.Length]}.zs{(FileEvents.MFirst ? 'm' : 's')}";
                SetJsonFilePath(FilePath);
                Json = Cmd.LoadJson(JsonFilePath)!;
                PlatformInfo = new(Json.Platform);
                if (Json.Samples.Count != 0)
                {
                    for (int i = 0; i < Json.Sounds.Count; i++)
                    {
                        JsonSound S = Json.Sounds[i];
                        S.Hash = Hashing.EnsureHash(S.Hash, FileEvents);
                        Sounds.Add(new(S, Json.Samples));
                    }
                }
            }
            else
            {
                Json = new();
                ZsndFilePath = FilePath;
                SetJsonDir(Settings.Shared.UI.ExtractedAssetsPath); // WIP: Better path?
                PlatformInfo = Cmd.LoadZsnd(ZsndFilePath, JsonFilePath, Sounds, Json.Samples) ?? new("PC");
                Json.Platform = PlatformInfo.String;
            }
            //if (Name.StartsWith("X_VOICE"))
            //    Lists.XVSounds = [.. ZJ.Sounds];
            FilteredSounds ??= new(Sounds);
            if (Samples is null) { Samples = new(Json.Samples); }
            else { for (int i = 0; i < Json.Samples.Count; i++) { Samples.Add(Json.Samples[i]); } }
            _updating = false;
        }

        internal void SaveJson()
        {
            if (!PendingChanges) { return; }
            SaveJson(JsonFilePath);
        }

        private void SaveJson(string FilePath)
        {
            if (Cmd.SaveJson(FilePath, Sounds, Samples, PlatformInfo) is string ErrorMsg)
            {
            }
        }

        internal async Task<string?> SaveZsnd()
        {
            if (!PendingChanges) { return null; }
            // WIP: Do we need to apply FilteredSounds?
            //      Handle all tries at WriteZsnd?
            return await Task.Run(() =>
            {
                try
                {
                    //if (Cmd.SaveJson(JsonFilePath, Sounds, Samples, PlatformInfo) is string ErrorMsg) { return ErrorMsg; }
                    return Cmd.WriteZsnd(ZsndFilePath, Sounds, Samples, PlatformInfo);
                }
                catch (Exception ex)
                {
                    return $"Failed to write '{ZsndFilePath}'.\n{ex}.";
                }
            }).WaitAsync(TimeSpan.FromMinutes(1));
        }

        internal void SaveFile(string FilePath, string Extension, string DisplayName)
        {
            Name = DisplayName;
            if (Extension.Equals(".json", StringComparison.OrdinalIgnoreCase))
            {
                JsonFilePath = FilePath;
                ZsndFilePath = $"{FilePath[..^Extension.Length]}.zs{(FileEvents.MFirst ? 'm' : 's')}";
                SaveJson(FilePath);
            }
            else
            {
                ZsndFilePath = FilePath;
                // WIP: Same as in LoadFile, but needs to be improved
                // WIP: Combine with other SaveZsnd
            }
        }
        /// <summary>
        /// Adds the <paramref name="Sound"/> to the <see cref="FilteredSounds"/> collection and the <see cref="Sounds"/> list.
        /// </summary>
        internal void AddSound(UISound Sound)
        {
            FilteredSounds.Add(Sound);
            Sounds.Add(Sound);
        }
        /// <summary>
        /// Adds a new sound to the <see cref="FilteredSounds"/> collection and the <see cref="Sounds"/> list. Uses the properties from the <see cref="SelectedSound"/>.
        /// </summary>
        internal void AddSound() { AddSound(SelectedSound is null ? new() : new UISound(SelectedSound.Hash, -1, SelectedSound.Flags)); }
        /// <summary>
        /// Adds a new audio <paramref name="Sample"/> to the (WIP: place to extract, headerless & normal), converting and storing the file as needed.
        /// </summary>
        /// <returns>The zero-based index of the newly added sample if successful; otherwise, -1 if the sample could not be added
        /// due to file incompatibility or if the maximum number of samples has been reached.</returns>
        internal int AddSample(Windows.Storage.StorageFile Sample)
        {
            //FileIncompatible.IsOpen = FileMaxReached.IsOpen = false;
            int NewIndex = Samples.Count;
            if (NewIndex > 0xFFFF)
            {
                //FileMaxReached.IsOpen = true;
                return -1;
            }
            string New = Path.Combine(JsonDir, "new"); // WIP: Configurable directory?
            JsonSample SampleInfo = new();
            try
            {
                _ = Directory.CreateDirectory(New);
                // WAV and VAG are headerless, DSP has special header, XMA has original RIFF header, Xbox ADPCM is unhandled at this time
                if (ZsndConvert.From(Sample.FileType, Sample.Path, SampleInfo, PlatformInfo) is byte[] ConvertedFileBuffer && ConvertedFileBuffer.Length != 0) // "RIFF"
                {
                    File.WriteAllBytes(Path.Combine(New, Sample.Name), ConvertedFileBuffer);
                }
                else
                {
                    SampleInfo.Format = 106;
                    SampleInfo.Sample_rate = 22050;
                    ZsndConvert.To(SampleInfo, Sample.Path, ".wav");
                    File.Copy(Sample.Path, Path.Combine(New, Sample.Name), true);
                }
                SampleInfo.File = Path.Combine("new", Sample.Name);
                Samples.Add(SampleInfo);
                return NewIndex;
            }
            catch
            {
                //FileIncompatible.IsOpen = true;
                return -1;
            }

        }
        /// <summary>
        /// Adds a new audio <paramref name="Sample"/> to the (WIP: place to extract, headerless & normal), converting and storing the file as needed & adds a new default sound, if the sample was added successfully.
        /// </summary>
        internal void AddSampleSound(Windows.Storage.StorageFile Sample)
        {
            if (AddSample(Sample) is int Index && Index != -1)
            { AddSound(new() { SampleIndex = Index, Sample = Path.GetFileName(Samples[Index].File), PendingChanges = false }); }
        }

        internal void SortSounds(string SortTag)
        {
            FilteredSounds.Sort(
                SortTag == "hash.asc"
                ? static c => c.OrderBy(static s => s.Hash)
                : SortTag == "hash.desc"
                ? static c => c.OrderByDescending(static s => s.Hash)
                : SortTag == "file.asc"
                ? static c => c.OrderBy(static s => s.Sample)
                : SortTag == "file.desc"
                ? static c => c.OrderByDescending(static s => s.Sample)
                : SortTag == "index.asc"
                ? static c => c.OrderBy(static s => s.SampleIndex)
                : SortTag == "index.desc"
                ? static c => c.OrderByDescending(static s => s.SampleIndex)
                : static c => c.OrderBy(static s => s)); // never happens
            if (Sounds.Count == FilteredSounds.Count) { Sounds = [.. FilteredSounds]; }
        }

        internal Task FilterSounds(string Filter)
        {
            Func<UISound, bool> FilterMatches = Filter.Length == 0 ? (s => true) : (s =>
            {
                return s.SampleIndex != -1
                    ? s.Hash.Contains(Filter, StringComparison.OrdinalIgnoreCase)
                        || Samples[s.SampleIndex].File.AsSpan().Contains(Filter, StringComparison.OrdinalIgnoreCase)
                    : s.Hash.Contains(Filter, StringComparison.OrdinalIgnoreCase);
            });
            return Task.Run(() =>
            {
                _ = DispatcherQueue.TryEnqueue(() =>
                {
                    for (int i = 0; i < Sounds.Count; i++)
                    {
                        UISound S = Sounds[i];
                        if (FilterMatches(S))
                        {
                            if (!FilteredSounds.Contains(S)) { FilteredSounds.Add(S); }
                        }
                        else { _ = FilteredSounds.Remove(S); }
                    }
                });
            });
        }
