        internal void RemoveSelected() => _ = SelectedSound is UISound Sound && FilteredSounds.Remove(Sound) && Sounds.Remove(Sound);

        partial void OnNameChanged(string value)
        {
            string NameUpper = value.ToUpperInvariant();
            BaseName = value.Length > 2 && value[^2] is '_' ? NameUpper[..^2] : NameUpper;
            FileEvents.Update(NameUpper, BaseName);
        }

        partial void OnSampleRateChanged(uint value)
        {
            if (_updating || SelectedSound is null || SelectedSound.SampleIndex == -1
                || Json.Samples[SelectedSound.SampleIndex].Sample_rate == value) { return; }
            Json.Samples[SelectedSound.SampleIndex].Sample_rate = value;
            PendingChanges = true;
        }

        partial void OnLoopChanged(bool value)
        {
            if (_updating || SelectedSound is null || SelectedSound.SampleIndex == -1) { return; }
            JsonSample S = Json.Samples[SelectedSound.SampleIndex];
            if (value == S.Flags.HasFlag(Properties.SampleF.Loop)) { return; }
            S.Flags = value ? S.Flags | Properties.SampleF.Loop : S.Flags & ~Properties.SampleF.Loop;
            PendingChanges = true;
        }

        internal void HashToEvents() => OnSelectedSoundChanged(SelectedSound);

        partial void OnSelectedSoundChanged(UISound? value)
        {
            if (value is null || value.Hash.Length == 0) { return; }
            _updating = true;
            int le = value.Hash.Length;
            int ix = value.Hash.IndexOf('/'); if (ix == -1) { ix = le - 1; }
            _ = Enum.TryParse(value.Hash[..ix], out Events.Category C); ix++;
            IndexCategory = (int)C;
            switch (C)
            {
                case Events.Category.CHAR or Events.Category.CHARACTER:
                    int ni = value.Hash.LastIndexOf('/', le - 1, le - ix); if (ni == -1) { ni = ix; }
                    CharacterIsV = value.Hash[ni - 1] is 'V'; // '/' if no second/last slash found
                    value.CharFile ??= ix < ni - 2 ? value.Hash[ix..(ni - 2)] : BaseName; ni++;
                    if (CharacterIsV) { IndexVoice = Events.Voice.IndexOf(value.Hash[ni..]); }
                    else { IndexMaster = Events.Master.IndexOf(value.Hash[ni..]); }
                    break;
                case Events.Category.COMMON:
                    ReadOnlySpan<char> sc = value.Hash.AsSpan();
                    Events.MenuPrefix p = le > 23 && sc[13] is 'C' && sc.Slice(ix, 16).SequenceEqual(Events.MenuPrefixes[4]) // or sc.Equals("MENUS/CHARACTER/", StringComparison.OrdinalIgnoreCase);
                        ? le > 26 && sc[23] is 'A' && sc[24] is 'N'
                            ? Events.MenuPrefix.AN : le > 29 && sc.Slice(23, 5).SequenceEqual("BREAK")
                            ? Events.MenuPrefix.BREAK
                            : Events.MenuPrefix.CHARACTER
                        : le > 18 && sc[ix] is 'T' && sc.Slice(ix, 16).SequenceEqual(Events.MenuPrefixes[1])
                            ? Events.MenuPrefix.TEAM
                        : le > 19 && Enum.TryParse(sc[13..(sc[17] is '/' ? 17 : sc[18] is '/' ? 18 : le)],
                            out Events.MenuPrefix op) ? op // doesn't check sc.Slice(ix, 6).SequenceEqual("MENUS/")
                            : Events.MenuPrefix.OTHER;
                    IndexMenu = (int)p;
                    MenuName = value.Hash[(7 + Events.MenuPrefixes[IndexMenu].Length)..];
                    break;
                case Events.Category.MUSIC: // WIP: Other events?
                    ReadOnlySpan<char> sm = value.Hash.AsSpan();
                    IndexMusic = le > 12 && sm.Slice(ix, 4).SequenceEqual("CUES")
                        ? sm[11] is 'I' && sm[12] is 'N'
                            ? 3 : 4
                        : le > 8 && sm[^2] is '_'
                            ? Events.MusSfxs.IndexOf(sm[^1])
                            : 6;
                    break;
                case Events.Category.VOICE: // Conversation voices, WIP: Do they need an extra box?
                default:
                    if (string.Equals(value.Hash, "STATSCREEN/AMB", StringComparison.OrdinalIgnoreCase)) // rare case
                    { IndexCategory = 4; IndexMusic = 5; }
                    break;
            }
            if (value.SampleIndex != -1)
            {
                SampleRate = Json.Samples[value.SampleIndex].Sample_rate;
                Loop = Json.Samples[value.SampleIndex].Flags.HasFlag(Properties.SampleF.Loop);
            }
            _updating = false;
        }

        partial void OnCharacterIsVChanged(bool value)
        {
            CharacterIsM = !value;
            if (_updating) { return; }
            if (value) { CharEventsChanged('V', IndexVoice, Events.Voice); }
            else { CharEventsChanged('M', IndexMaster, Events.Master); }
        }

        internal void CharEventsChanged(char type, int index, string[] events)
        {
            if (_updating || SelectedSound is null || index == -1) { return; }
            SelectedSound.Hash = $"{Events.Categories[IndexCategory]}/{SelectedSound.CharFile}_{type}/{events[index]}";
            PendingChanges = true;
        }

        partial void OnIndexCategoryChanged(int oldValue, int newValue)
        {
            if (newValue != -1 && SelectedSound is not null)
            {
                switch (newValue)
                {
                    case 1 or 2: MenuEvent = MusicEvent = !(CharacterEvent = true); break;
                    case 3: CharacterEvent = MusicEvent = !(MenuEvent = true); break;
                    case 4: CharacterEvent = MenuEvent = !(MusicEvent = true); break;
                    case 5 or 0:
                    default: CharacterEvent = MenuEvent = MusicEvent = false; break;
                }
                if (_updating) { return; }
                string end = oldValue == 0 ? SelectedSound.Hash
                    : SelectedSound.Hash[(SelectedSound.Hash.IndexOf('/') + 1)..];
                SelectedSound.Hash = newValue == 0 ? end : $"{Events.Categories[newValue]}/{end}";
                PendingChanges = true;
            }
        }

        partial void OnIndexMasterChanged(int value) => CharEventsChanged('M', value, Events.Master);

        partial void OnIndexVoiceChanged(int value) => CharEventsChanged('V', value, Events.Voice);

        partial void OnIndexMenuChanged(int value)
        {
            if (_updating || SelectedSound is null || MenuName is null || value == -1) { return; }
            if (value == 1)
            {
                _updating = true;
                if (MenuName.StartsWith("TEAM_BONUS_", StringComparison.OrdinalIgnoreCase)) { MenuName = (MenuName[11..]); }
                else if (MenuName.StartsWith("BONUS_", StringComparison.OrdinalIgnoreCase)) { MenuName = (MenuName[6..]); }
                _updating = false;
            }
            SelectedSound.Hash = $"COMMON/{Events.MenuPrefixes[value]}{MenuName}";
            PendingChanges = true;
        }

        partial void OnIndexMusicChanged(int value)
        {
            if (_updating || SelectedSound is null || value == -1) { return; }
            if (value == 6 && SelectedSound.Hash.StartsWith("MUSIC/", StringComparison.OrdinalIgnoreCase)) { return; }
            SelectedSound.Hash = value == 6 ? $"MUSIC/{SelectedSound.Hash}" : Events.Music[value];
            PendingChanges = true;
        }

