        }

        internal void SampleChanged(JsonSample Sample)
        {
            if (_updating || SelectedSound is null || !SelectedSound.PendingChanges) { return; }
            Loop = Sample.Flags.HasFlag(Properties.SampleF.Loop);
            SampleRate = Sample.Sample_rate;
            SelectedSound.Sample = Path.GetFileName(Sample.File);
            SelectedSound.PendingChanges = !(PendingChanges = true);
        }

        public override string ToString() => Name;
    }
