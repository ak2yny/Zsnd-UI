<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Zsnd_UI.Controls.Tab_SoundsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lib="using:Zsnd_UI.lib"
    mc:Ignorable="d"
    DataContextChanged="SoundsView_DataContextChanged">

    <UserControl.Resources>
        <Style x:Key="PillToggleSwitchStyle" TargetType="ToggleSwitch">
            <Setter Property="Background" Value="{ThemeResource ToggleButtonBackground}"/>
            <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
            <Setter Property="BorderBrush" Value="{ThemeResource ToggleButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="{ThemeResource ToggleButtonBorderThemeThickness}" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            <Setter Property="Foreground" Value="{ThemeResource ToggleButtonForeground}" />
            <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
            <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
            <Setter Property="FocusVisualMargin" Value="-3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleSwitch">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              BackgroundSizing="{TemplateBinding BackgroundSizing}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="SwitchPill" Height="32"
                                    Background="{ThemeResource ToggleButtonBackgroundChecked}"
                                    BackgroundSizing="{ThemeResource ToggleButtonCheckedStateBackgroundSizing}">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="PillTranslateTransform" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter x:Name="OffContentPresenter"
                                              Foreground="{TemplateBinding Foreground}"
                                              Content="{TemplateBinding OffContent}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              AutomationProperties.AccessibilityView="Raw" />
                            <ContentPresenter x:Name="OnContentPresenter" Grid.Column="1"
                                              Foreground="{TemplateBinding Foreground}"
                                              Content="{TemplateBinding OnContent}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              AutomationProperties.AccessibilityView="Raw" />
                            <!--ContentTemplate="{TemplateBinding OnContentTemplate}"-->
                            <!--Note: Foreground visual states seem to depend on on theme (pointer over: white foreground).-->
                            <Border x:Name="ButtonBorder" Grid.ColumnSpan="2"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <Thumb x:Name="SwitchThumb" Grid.ColumnSpan="2" CornerRadius="{TemplateBinding CornerRadius}" AutomationProperties.AccessibilityView="Raw"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <!--BG is handled by the Thumb (alt: RootGrid ToggleButtonBackgroundPointerOver)
                                                Foreground ToggleButtonForegroundPointerOver, ToggleButtonForegroundCheckedPointerOver-->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonBorderBrushPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <!-- Just an example for form animation (needs normal):
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SwitchKnobOff" Storyboard.TargetProperty="Height" EnableDependentAnimation="True">
                                                    <SplineDoubleKeyFrame KeyTime="{StaticResource ControlFasterAnimationDuration}" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" Value="14" />
                                                </DoubleAnimationUsingKeyFrames>-->
                                            <!--Just an example for color animation (might need normal):
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetName="OuterBorder" Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)">
                                                <LinearColorKeyFrame KeyTime="{StaticResource ControlFasterAnimationDuration}" Value="{ThemeResource ToggleSwitchFillOffPointerOver}" />
                                            </ColorAnimationUsingKeyFrames>-->
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Pressed">
                                        <!--<VisualState.Setters>
                                                <Setter Target="SwitchPill.HorizontalAlignment" Value="Left" />
                                                <Setter Target="SwitchPill.Margin" Value="-3 0 0 0" />
                                            </VisualState.Setters>-->

                                        <Storyboard>
                                            <!--BG is handled by the Thumb (alt: RootGrid ToggleButtonBackgroundPressed, ToggleButtonBackgroundCheckedPressed)
                                                Foreground ToggleButtonForegroundPressed, ToggleButtonForegroundCheckedPressed
                                                alt border: ButtonBorder ToggleButtonBorderBrushCheckedPressed-->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SwitchPill" Storyboard.TargetProperty="Margin">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="-2 0" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonBorderBrushPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <!--Checked foreground: ToggleButtonForegroundCheckedDisabled
                                                alt border: ButtonBorder ToggleButtonBorderBrushCheckedDisabled-->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonBackgroundDisabled}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SwitchPill" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonBackgroundCheckedDisabled}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonBorderBrushDisabled}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OnContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonForegroundDisabled}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OffContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonForegroundDisabled}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>

                                </VisualStateGroup>
                                <VisualStateGroup x:Name="ToggleStates">
                                    <VisualState x:Name="Dragging"/>
                                    <VisualState x:Name="Off"/>
                                    <VisualState x:Name="On">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PillTranslateTransform" Storyboard.TargetProperty="X" To="20" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="ContentStates">
                                    <VisualState x:Name="OffContent">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OffContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonForegroundChecked}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="OnContent">
                                        <Storyboard>
                                            <!--ToggleButtonBorderBrushChecked-->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OnContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ToggleButtonForegroundChecked}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="0 0 0 8">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger x:Name="CommandBarWidthThreashold" MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                            <Setter Target="SearchBar.IsDynamicOverflowEnabled" Value="True" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <CommandBar x:Name="SearchBar" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="False"
                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center"
                    OverflowButtonVisibility="Auto">
            <CommandBar.Content>
                <!--WIP: Possibly add replacement text-->
                <AutoSuggestBox x:Name="Filter" Loaded="Filter_Loaded" QueryIcon="Find" TextChanged="Filter_TextChanged">
                    <AutoSuggestBox.KeyboardAccelerators>
                        <KeyboardAccelerator Invoked="Filter_Invoked" Key="F3"/>
                        <KeyboardAccelerator Invoked="Filter_Invoked" Key="F" Modifiers="Control"/>
                    </AutoSuggestBox.KeyboardAccelerators>
                </AutoSuggestBox>
            </CommandBar.Content>
            
            <AppBarSeparator/>
            <AppBarButton x:Uid="CommandBarSort" Icon="Sort" AutomationProperties.Name="Sort">
                <AppBarButton.Flyout>
                    <MenuFlyout Placement="Left">
                        <MenuFlyoutItem x:Uid="CommandBarSortHA" Click="SoundLV_Sorting" Tag="hash.asc" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortHD" Click="SoundLV_Sorting" Tag="hash.desc" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortScA" Click="SoundLV_Sorting" Tag="source.asc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortScD" Click="SoundLV_Sorting" Tag="source.desc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="CommandBarSortSA" Click="SoundLV_Sorting" Tag="name.asc"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortSD" Click="SoundLV_Sorting" Tag="name.desc"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="CommandBarSortIA" Click="SoundLV_Sorting" Tag="index.asc" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortID" Click="SoundLV_Sorting" Tag="index.desc" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortSRA" Click="SoundLV_Sorting" Tag="sr.asc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortSRD" Click="SoundLV_Sorting" Tag="sr.desc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="CommandBarSortApply" Click="SoundLV_SortApply" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortRestore" Click="SoundLV_SortRestore" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortFA" Click="SoundLV_Sorting" Tag="flags.asc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                        <MenuFlyoutItem x:Uid="CommandBarSortFD" Click="SoundLV_Sorting" Tag="flags.desc" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:Uid="CommandBarAddSound" Click="AddSound_Click" Icon="Add" Visibility="{x:Bind File.SampleEditorClosed, Mode=OneWay}"/>
            <AppBarButton x:Uid="CommandBarBrowseSound" Click="BrowseSamples_Click" Icon="OpenLocal"/>
            <AppBarButton x:Uid="CommandBarExtract" Icon="Download">
                <AppBarButton.Flyout>
                    <MenuFlyout Placement="Left">
                        <MenuFlyoutItem x:Uid="CommandBarExtractAudio" Click="ExtractSamples_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Key="E" Modifiers="Control"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="CommandBarExtractRaw" Click="ExtractSamplesRaw_Click"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:Uid="CommandBarBack" Click="BackButton_Click" Icon="Back" Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}"/>

            <!--<CommandBar.SecondaryCommands>
                <AppBarToggleButton Click="AddSound_Click" Icon="OpenLocal" Label="Browse..." ToolTipService.ToolTip="Browse for sound files to add."/>
            </CommandBar.SecondaryCommands>-->
        </CommandBar>
        <SplitView x:Name="SplitView" Grid.Row="1"
                   DisplayMode="Inline"
                   IsPaneOpen="True"
                   OpenPaneLength="360"
                   PanePlacement="Right">
            <!--ThemeResource backgrounds:
            SystemControlPageBackgroundChromeLowBrush / ApplicationPageBackgroundThemeBrush (same?)
            SystemControlPageBackgroundAltHighBrush-->
            <SplitView.Content>
                <Grid>
                    <ListView x:Name="SoundListView" Grid.Row="1" Margin="0 0 8 0"
                              AllowDrop="True"
                              CanDragItems="True"
                              CanReorderItems="True"
                              DragItemsStarting="SoundsList_DragItemsStarting"
                              DragOver="SoundsList_DragOver"
                              Drop="SoundsList_Drop"
                              KeyboardAcceleratorPlacementMode="Hidden"
                              ItemsSource="{x:Bind File.FilteredSounds, Mode=OneWay}"
                              SelectedItem="{x:Bind File.SelectedSound, Mode=TwoWay}"
                              SelectionMode="Extended">
                        <!--SelectionMode="Extended"-->
                        <ListView.ItemTemplate>
                            <DataTemplate x:Name="SoundsTemplate" x:DataType="lib:UISound">
                                <Grid ColumnSpacing="5" Background="{ThemeResource SystemControlPageBackgroundAltHighBrush}" DoubleTapped="Sound_DoubleTapped" Padding="7" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition MaxWidth="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind Hash, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="1" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind Sample.Name, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="2" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind Flags, Mode=OneWay}" HorizontalAlignment="Right"/>
                                    <!--<controls:BorderedTextBlock Grid.Column="0" Text="{x:Bind Hash, Mode=OneWay}"/>
                                    <controls:BorderedTextBlock Grid.Column="1" Text="{x:Bind SampleName, Mode=OneWay}"/>
                                    <controls:BorderedTextBlock Grid.Column="2" Text="{x:Bind Flags, Mode=OneWay}" HorizontalAlignment="Right"/>-->
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Delete" Invoked="SoundsList_Delete" ScopeOwner="{x:Bind SoundListView}"/>
                            <KeyboardAccelerator Key="Space" Invoked="Play_Sound"/>
                        </ListView.KeyboardAccelerators>
                    </ListView>
                    <ProgressRing x:Name="SearchInProgress" IsActive="False" Visibility="Collapsed"/>
                    <Button x:Name="SidebarToggle"
                            BorderThickness="1"
                            Click="SidebarToggle_Click"
                            Height="240" Width="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Padding="0">
                        <Button.Content>
                            <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                        </Button.Content>
                    </Button>
                </Grid>
            </SplitView.Content>

            <SplitView.Pane>
                <ScrollView Grid.Row="1" Grid.Column="1" Margin="5 0">
                    <Grid RowSpacing="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Expander x:Name="HashEditor" x:Uid="SelectedHashExpander"
                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <Grid ColumnSpacing="5" RowSpacing="5">
                                <Grid.Resources>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
                                        <Setter Property="HeaderTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ComboBox x:Name="Category" x:Uid="SampleHashCategory"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind lib:Events.Categories}"
                                          SelectedIndex="{x:Bind File.IndexCategory, Mode=TwoWay}"/>
                                <Grid ColumnSpacing="2" Grid.Row="1" Visibility="{x:Bind File.CharacterEvent, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CharName" x:Uid="SampleHashCharName" Grid.Row="1" MaxWidth="100"
                                             CharacterCasing="Upper"
                                             Text="{x:Bind File.SelectedSound.CharFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"/>
                                    <!--Alternative native control, but complicated binding/changed checks
                                    <SelectorBar x:Name="CharFileType" Grid.Column="1" VerticalAlignment="Bottom">
                                        <SelectorBarItem x:Name="AvailChars" Padding="5 1" Text="V"/>
                                        <SelectorBarItem x:Name="AvailChars2" Padding="5 1" Text="M"/>
                                    </SelectorBar>-->
                                    <ToggleSwitch x:Name="CharFileType" Grid.Column="1"
                                                  Style="{StaticResource PillToggleSwitchStyle}"
                                                  IsOn="{x:Bind File.CharacterIsV, Mode=TwoWay}"
                                                  OffContent="M" OnContent="V"
                                                  VerticalAlignment="Bottom" Width="40"/>
                                    <ComboBox x:Name="MEvents" x:Uid="SampleHashMEvent" Grid.Column="2"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind lib:Events.Master}"
                                              SelectedIndex="{x:Bind File.IndexMaster, Mode=TwoWay}"
                                              Visibility="{x:Bind File.CharacterIsM, Mode=OneWay}"/>
                                    <!--Visibility="{x:Bind File.CharacterEvent, Mode=OneWay}"-->
                                    <ComboBox x:Name="VEvents" x:Uid="SampleHashVEvent" Grid.Column="2"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind lib:Events.Voice}"
                                              SelectedIndex="{x:Bind File.IndexVoice, Mode=TwoWay}"
                                              Visibility="{x:Bind File.CharacterIsV, Mode=OneWay}"/>
                                </Grid>
                                <ComboBox x:Name="MenuPrefixes" x:Uid="SampleHashMenuEvent" Grid.Row="1" Width="130"
                                          ItemsSource="{x:Bind lib:Events.MenuTypes}"
                                          SelectedIndex="{x:Bind File.IndexMenu, Mode=TwoWay}"
                                          Visibility="{x:Bind File.MenuEvent, Mode=OneWay}"/>
                                <TextBox x:Name="MenuName" x:Uid="SampleHashMenuName" Grid.Row="1" Margin="132 0 0 0"
                                         CharacterCasing="Upper"
                                         Text="{x:Bind File.MenuName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTipService.ToolTip="Internal herostat name, team bonus name or other menu event name"
                                         Visibility="{x:Bind File.MenuEvent, Mode=OneWay}"/>
                                <ComboBox x:Name="MusicEvent" x:Uid="SampleHashMusicEvent" Grid.Row="1"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind File.FEvents.MusicEvents, Mode=OneWay}"
                                          SelectedIndex="{x:Bind File.IndexMusic, Mode=TwoWay}"
                                          Visibility="{x:Bind File.MusicEvent, Mode=OneWay}"/>
                                <Grid ColumnSpacing="2" Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!--Wrap disables the clear button-->
                                    <TextBox x:Name="HashEdit" x:Uid="SampleHashEdit" Grid.Row="2"
                                             CharacterCasing="Upper"
                                             Text="{x:Bind File.SelectedSound.Hash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button x:Uid="SampleHashSync" Click="UpdateEvents_Click" Grid.Column="1" VerticalAlignment="Bottom">
                                        <SymbolIcon Symbol="Sync"/>
                                        <Button.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="F5"/>
                                        </Button.KeyboardAccelerators>
                                    </Button>
                                    <Button x:Uid="SampleCopyHash" Click="CopyHash_Click" Grid.Column="2" VerticalAlignment="Bottom">
                                        <SymbolIcon Symbol="Copy"/>
                                        <Button.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="C" Modifiers="Control,Menu"/>
                                        </Button.KeyboardAccelerators>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Expander>
                        <Expander x:Uid="SelectedSampleExpander" Grid.Row="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                            <Grid RowSpacing="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ComboBox x:Name="SampleComboBox" x:Uid="SampleBox"
                                          DisplayMemberPath="Name"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind File.Samples, Mode=OneWay}"
                                          SelectedItem="{x:Bind File.SelectedSound.Sample, Mode=TwoWay}"/>
                                <Grid Grid.Row="1" ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Click="Play_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <SymbolIcon>Play</SymbolIcon>
                                            <TextBlock x:Uid="SamplePlay" Margin="10 0"/>
                                        </StackPanel>
                                        <Button.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Space"/>
                                        </Button.KeyboardAccelerators>
                                    </Button>
                                    <!--WIP: better? <MediaPlayerElement x:Name="SamplePlayer" Grid.Row="2" Margin="10" AreTransportControlsEnabled="True" AutoPlay="False" IsMuted="{x:Bind File.Sample.IsMuted, Mode=TwoWay}" Stretch="Uniform"/>-->
                                    <ComboBox x:Name="SampleRateComboBox" x:Uid="SampleRateBox"
                                              DropDownClosed="SampleRateComboBox_DropDownClosed"
                                              Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind lib:ZsndProperties.SampleRates}"
                                              SelectedItem="{x:Bind File.SelectedSound.Sample.SampleRate, Mode=TwoWay}"/>
                                    <Button x:Uid="SampleReorderButton" Click="SampleReorderButton_Click" Grid.Column="2">
                                        <SymbolIcon>List</SymbolIcon>
                                    </Button>
                                    <InfoBar x:Name="SoundNotPlayed" x:Uid="SoundNotPlayed" Grid.ColumnSpan="3" Grid.Row="1" Severity="Warning"/>
                                </Grid>
                                <Rectangle Grid.Row="2" Margin="10"
                                           RadiusX="4" RadiusY="4"
                                           Stroke="{ThemeResource SystemAccentColor}" StrokeDashArray="6 3" StrokeThickness="3"/>
                                <TextBlock x:Uid="SampleDropAddFile" TextAlignment="Center" TextWrapping="Wrap"
                                           Foreground="Gray" Grid.Row="2"
                                           HorizontalAlignment="Center"
                                           Margin="15"
                                           VerticalAlignment="Center"/>
                                <Border AllowDrop="True" Background="Transparent" DragEnter="SampleDropArea_DragEnter" Grid.Row="2"/>
                                <Rectangle x:Name="SampleDropArea" Grid.Row="2"
                                           AllowDrop="True"
                                           DragOver="SampleDropAreaBG_DragOver"
                                           DragLeave="SampleDropAreaBG_DragLeave"
                                           Drop="SampleDropAreaBG_Drop" 
                                           Fill="{ThemeResource ListViewItemPointerOverBackgroundThemeBrush}"
                                           RadiusX="4" RadiusY="4"
                                           Visibility="Collapsed"/>
                                <MenuFlyoutSeparator Grid.Row="3"/>
                                <CheckBox x:Uid="SampleOptionLoop" Grid.Row="4" IsChecked="{x:Bind File.SelectedSound.Loop, Mode=TwoWay}"/>
                                <TextBlock x:Uid="SampleOptions" Grid.Row="4" Margin="5"
                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Run Text="{x:Bind File.SelectedSound.Sample.Flags, Mode=OneWay}"/>
                                    <Run Text="; "/>
                                    <Run Text="{x:Bind File.SelectedSound.Sample.Format, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </Expander>
                        <Expander x:Uid="SelectedPropertiesExpander" Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                            <StackPanel>
                                <TextBlock x:Uid="SoundOptionsHeader" TextWrapping="Wrap" Margin="0 0 0 10"/>
                                <CheckBox x:Uid="SoundOptionF1" IsChecked="{x:Bind File.SelectedSound.F1, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF2" IsChecked="{x:Bind File.SelectedSound.F2, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF3" IsChecked="{x:Bind File.SelectedSound.F3, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF4" IsChecked="{x:Bind File.SelectedSound.F4, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF5" IsChecked="{x:Bind File.SelectedSound.F5, Mode=TwoWay}"/>
                                <MenuFlyoutSeparator Margin="0 10"/>
                                <CheckBox x:Uid="SoundOptionF6" IsChecked="{x:Bind File.SelectedSound.F6, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF7" IsChecked="{x:Bind File.SelectedSound.F7, Mode=TwoWay}"/>
                                <CheckBox x:Uid="SoundOptionF8" IsChecked="{x:Bind File.SelectedSound.F8, Mode=TwoWay}"/>
                            </StackPanel>
                        </Expander>
                        <Expander x:Uid="ZSNDPropertiesExpander" Grid.Row="3" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                            <Grid RowSpacing="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBox x:Name="ExtractDirName" x:Uid="ZSNDExtractDirName" Text="{x:Bind File.ExtractedDirName, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="1" TextWrapping="Wrap">
                                    <Run x:Uid="ZSNDJsonDir"/><Run Text="{x:Bind File.JsonDir, Mode=OneWay}"/><Run Text="/"/><Run Text="{x:Bind File.ExtractedDirName, Mode=OneWay}"/>
                                    <LineBreak/>
                                    <Run x:Uid="ZSNDJsonPath"/><Run Text="{x:Bind File.JsonFilePath, Mode=OneWay}"/>
                                    <LineBreak/>
                                    <Run x:Uid="ZSNDPath"/><Run Text="{x:Bind File.ZsndFilePath, Mode=OneWay}"/>
                                </TextBlock>
                                <MenuFlyoutSeparator Grid.Row="2"/>
                                <ComboBox x:Name="PlatformComboBox" x:Uid="ZSNDPlatform" Grid.Row="3"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind lib:ZsndProperties.Platforms}"
                                          SelectedItem="{x:Bind File.PlatformInfo.ID, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Expander>
                    </Grid>
                </ScrollView>
            </SplitView.Pane>
        </SplitView>
        <ListView x:Name="SampleListView" Grid.Row="1" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}"
                  AllowDrop="True"
                  CanReorderItems="True"
                  KeyboardAcceleratorPlacementMode="Hidden"
                  ItemsSource="{x:Bind File.Samples, Mode=OneWay}"
                  SelectedIndex="{x:Bind File.SelectedSampleIndex, Mode=OneWay}"
                  SelectionMode="Extended"
                  Visibility="{x:Bind File.SampleEditorOpen, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:Name="SamplesTemplate" x:DataType="lib:UISample">
                    <Grid ColumnSpacing="12" Background="{ThemeResource SystemControlPageBackgroundAltHighBrush}" DoubleTapped="Sample_DoubleTapped" Padding="7" CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition MaxWidth="60"/>
                            <ColumnDefinition MaxWidth="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind Name}" ToolTipService.ToolTip="{x:Bind Name}"/>
                        <TextBlock Grid.Column="1" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind File}" ToolTipService.ToolTip="{x:Bind File}"/>
                        <TextBlock Grid.Column="2" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind SampleRate, Mode=OneWay}"/>
                        <TextBlock Grid.Column="3" MaxLines="1" TextTrimming="CharacterEllipsis" Text="{x:Bind Flags, Mode=OneWay}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.KeyboardAccelerators>
                <KeyboardAccelerator Key="Delete" Invoked="SampleList_Delete" ScopeOwner="{x:Bind SampleListView}"/>
            </ListView.KeyboardAccelerators>
        </ListView>
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind File.TaskInfo.IsNotCompleted, Mode=OneWay}"
                      Visibility="{x:Bind File.TaskInfo.IsNotCompleted, Mode=OneWay}"/>
        <StackPanel Grid.Row="1" Margin="10" VerticalAlignment="Bottom">
            <!--<InfoBar x:Name="FileSuccess" x:Uid="FileSuccessInfo" Severity="Success"/>-->
            <InfoBar x:Name="FileIncompatible" x:Uid="FileErrorIncompatible" Severity="Error"/>
            <InfoBar x:Name="FileMaxReached" x:Uid="FileErrorMaxReached" Severity="Error"/>
            <InfoBar x:Name="FileError" x:Uid="FileErrorFailed"
                     IsOpen="{x:Bind File.TaskInfo.IsFaulted, Mode=OneWay}"
                     Severity="Error">
                <StackPanel Margin="0 -10 0 10">
                    <TextBlock x:Name="Subtitle" Text="{x:Bind File.ErrorSubtitle, Mode=OneWay}" Visibility="{x:Bind File.TaskInfo.ShowErrorSubtitle, Mode=OneWay}"/>
                    <TextBlock x:Name="Message" Text="{x:Bind File.TaskInfo.ErrorMessage, Mode=OneWay}"/>
                </StackPanel>
            </InfoBar>
        </StackPanel>
    </Grid>
</UserControl>
